# =====================================================
# Sourcing Tracker (쿠팡/알리바바)
# =====================================================

# 쿠팡 윙 OPEN API
COUPANG_ACCESS_KEY=your_coupang_access_key
COUPANG_SECRET_KEY=your_coupang_secret_key
COUPANG_VENDOR_ID=your_vendor_id (업체코드, 예: A00193321)

# 1688/알리바바 오픈 플랫폼 API
ALIBABA_APP_KEY=your_alibaba_app_key
ALIBABA_APP_SECRET=your_alibaba_app_secret
ALIBABA_ACCESS_TOKEN=your_alibaba_access_token

# ScraperAPI (스크래퍼 프록시)
SCRAPER_API_KEY=your_scraperapi_key                    # ⚠ 백엔드 전용 (HTML/client 노출 금지)


# =====================================================
# DIVOOST SNS Platform - Supabase
# =====================================================
# 클라이언트 코드에 노출되는 값 (RLS로 보호됨, OK)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# 백엔드 전용 - 절대 클라이언트 노출 금지
# Supabase Edge Functions에 자동 주입되지만 로컬 테스트 시 필요
SUPABASE_SERVICE_ROLE_KEY=eyJ...                      # ⚠ 백엔드 전용


# =====================================================
# DIVOOST SNS Platform - AI 프로바이더 (회사 마스터 키)
# =====================================================
# Supabase Edge Functions Secrets에 설정
# 위치: Supabase Dashboard > Project Settings > Edge Functions > Secrets

# Replicate (1순위 - 가장 많은 모델)
# 발급: https://replicate.com/account/api-tokens
REPLICATE_API_KEY=r8_...

# Fal.ai (2순위 - 빠른 inference)
# 발급: https://fal.ai/dashboard/keys
FAL_API_KEY=...

# OpenAI (DALL-E 3, GPT-4)
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Anthropic Claude (텍스트 생성, 선택)
ANTHROPIC_API_KEY=sk-ant-...


# =====================================================
# DIVOOST SNS Platform - 결제 PG (Phase 2)
# =====================================================
# 토스페이먼츠 (국내 메인)
TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...

# Stripe (해외 자동 구독)
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...                          # ⚠ 백엔드 전용
STRIPE_WEBHOOK_SECRET=whsec_...                        # ⚠ 백엔드 전용

# PayPal (해외)
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...                               # ⚠ 백엔드 전용

# 카카오페이 / 네이버페이는 토스페이먼츠 통합으로 처리


# =====================================================
# DIVOOST SNS Platform - SNS API (회사 인증용)
# =====================================================
# Facebook (Meta) - 회사 앱 비밀번호
# App ID는 public이라 클라이언트 노출 OK, Secret은 백엔드 전용
META_APP_ID=1774380433543061                           # public, client OK
META_APP_SECRET=...                                    # ⚠ 백엔드 전용 (장기 토큰 교환용)

# TikTok Content Posting API
TIKTOK_CLIENT_KEY=...
TIKTOK_CLIENT_SECRET=...                               # ⚠ 백엔드 전용

# 네이버 OpenAPI (블로그/카페)
NAVER_CLIENT_ID=...
NAVER_CLIENT_SECRET=...                                # ⚠ 백엔드 전용


# =====================================================
# DIVOOST SNS Platform - 이메일 발송
# =====================================================
# Resend.com (또는 SendGrid)
RESEND_API_KEY=re_...                                  # ⚠ 백엔드 전용
RESEND_FROM_EMAIL=noreply@divoost.com


# =====================================================
# 보안 규칙
# =====================================================
# 1. 이 파일은 *.example 이라 깃에 올라감 (실제 값 없음)
# 2. 실제 값은 .env (gitignore됨)에만 작성
# 3. ⚠ "백엔드 전용" 표시된 값은 절대 client/HTML에 노출 금지
# 4. 노출되면 즉시 회전 (provider 대시보드에서 키 재발급)
# 5. Supabase Edge Functions Secrets는 Dashboard에서 별도 입력
